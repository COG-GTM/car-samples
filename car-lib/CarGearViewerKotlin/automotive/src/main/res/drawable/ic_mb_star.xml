<?xml version="1.0" encoding="utf-8"?>
<!--
    Illustrative, self-drawn "three-pointed star in a ring" mark used only to
    evoke a Mercedes-Benz style header for this demo. This is NOT an official
    Mercedes-Benz trademark asset; it is drawn by hand from simple vector
    primitives (a ring plus three spokes) purely for demonstration purposes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Outer ring. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@color/mb_silver"
        android:strokeWidth="2.5"
        android:pathData="M24,3
            A21,21 0 1,0 24.001,3 Z" />

    <!-- Three spokes at 12, 4 and 8 o'clock forming the tri-star. -->
    <path
        android:strokeColor="@color/mb_silver"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M24,24 L24,4" />
    <path
        android:strokeColor="@color/mb_silver"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M24,24 L41.3,34" />
    <path
        android:strokeColor="@color/mb_silver"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M24,24 L6.7,34" />
</vector>
