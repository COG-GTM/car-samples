<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mb_black"
    android:orientation="vertical"
    android:padding="32dp"
    tools:context=".MainActivity">

    <!-- Header: self-drawn MB star + title. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/mb_star_description"
            android:src="@drawable/ic_mb_star" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:letterSpacing="0.05"
            android:text="@string/header_title"
            android:textColor="@color/mb_silver"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- PRND gear indicator (segment control). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/gearP"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/gear_p"
            android:textColor="@color/mb_dim"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gearR"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/gear_r"
            android:textColor="@color/mb_dim"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gearN"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/gear_n"
            android:textColor="@color/mb_dim"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gearD"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/gear_d"
            android:textColor="@color/mb_dim"
            android:textSize="56sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Telemetry tiles: speed + battery/fuel. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="horizontal">

        <!-- Speed tile -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/mb_surface"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.2"
                android:text="@string/speed_label"
                android:textColor="@color/mb_dim"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/speedValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dash"
                    android:textColor="@color/mb_silver"
                    android:textSize="72sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/speed_unit"
                    android:textColor="@color/mb_dim"
                    android:textSize="24sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Battery / fuel tile -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="24dp"
            android:background="@color/mb_surface"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/batteryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.2"
                android:text="@string/battery_label"
                android:textColor="@color/mb_dim"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/batteryPercentTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/placeholder_dash"
                android:textColor="@color/mb_silver"
                android:textSize="72sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/batteryBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/battery_bar_drawable" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
